{# views-view-unformatted--places-grid.html.twig #}
<style>
/* ===== FILTER BUTTONS ===== */

.filter-btns {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin: 30px 0 40px;
}

.filter-btn {
    padding: 10px 22px;
    border-radius: 30px;
    border: 1px solid #d7cfc5;
    background: #fff;
    color: #7a5c45;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
}

.filter-btn:hover {
    background: #f5f2ee;
}

.filter-btn.active {
    background: #ff7a00;
    color: #fff;
    border-color: #ff7a00;
}

/* ===== GRID ===== */

.places-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

/* ===== CARD ===== */

.place-card {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    transition: all 0.3s ease;
}

.place-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
}

/* Image */

.place-card-img img {
    width: 100%;
    height: 230px;
    object-fit: cover;
    display: block;
}

/* Body */

.place-card-body {
    padding: 18px 20px;
}

.place-card-body h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #2d2d2d;
}

.location {
    font-size: 13px;
    color: #888;
    margin-bottom: 8px;
}

.place-card-body p {
    font-size: 14px;
    color: #666;
    margin-bottom: 14px;
}

/* Footer */

.place-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.price {
    font-weight: 600;
    color: #ff7a00;
}
/* ===== SEARCH + FILTER WRAPPER ===== */

.search-filter {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin: 30px 0 40px;
}

/* Search */

.search-box input {
    width: 320px;
    padding: 12px 20px;
    border-radius: 30px;
    border: 1px solid #ddd;
    font-size: 14px;
    outline: none;
    transition: 0.3s;
}

.search-box input:focus {
    border-color: #ff7a00;
    box-shadow: 0 0 0 3px rgba(255,122,0,0.1);
}

/* Filter buttons */

.filter-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
}
</style>
<section class="destinations section-padding" id="destinations">
  <div class="container">

  <div class="section-title">
            <h2>Places to Visit in Ujjain</h2>
            <p>Explore the most revered temples, sacred ghats, and heritage sites of this ancient city</p>
        </div>

    {# ===== FILTER BUTTONS ===== #}
    {% set categories = [] %}

    {% for row in rows %}
      {% set node = row.content['#row']._entity %}
      {% for item in node.field_destination_category %}
        {% if item.entity %}
          {% set label = item.entity.label|lower|replace({' ': '-'}) %}
          {% if label not in categories %}
            {% set categories = categories|merge([label]) %}
          {% endif %}
        {% endif %}
      {% endfor %}
    {% endfor %}
<div class="search-filter">

  <div class="search-box">
    <input type="text" id="searchInput" placeholder="Search temples, ghats, heritage sites...">
  </div>

  <div class="filter-btns">
    <button class="filter-btn active" data-filter="all">All</button>

    {% for cat in categories %}
      <button class="filter-btn" data-filter="{{ cat }}">
        {{ cat|replace({'-': ' '})|title }}
      </button>
    {% endfor %}
  </div>

</div>

    {# ===== CARDS ===== #}
    <div class="places-grid">

      {% for row in rows %}
        {% set node = row.content['#row']._entity %}

        {% set groups = [] %}
        {% for item in node.field_destination_category %}
          {% if item.entity %}
            {% set group = item.entity.label|lower|replace({' ': '-'}) %}
            {% set groups = groups|merge([group]) %}
          {% endif %}
        {% endfor %}

        <div class="place-card"
             data-category="{{ groups|join(' ') }}">

          {{ row.content }}

        </div>
      {% endfor %}

    </div>

  </div>
</section>
<script>
document.addEventListener("DOMContentLoaded", function () {

  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll(".place-card");

  buttons.forEach(button => {
    button.addEventListener("click", function () {

      document.querySelector(".filter-btn.active")?.classList.remove("active");
      this.classList.add("active");

      const filter = this.dataset.filter;

      cards.forEach(card => {
        if (filter === "all") {
          card.style.display = "block";
        } else {
          const categories = card.dataset.category.split(" ");
          if (categories.includes(filter)) {
            card.style.display = "block";
          } else {
            card.style.display = "none";
          }
        }
      });

    });
  });

});
document.addEventListener("DOMContentLoaded", function () {

  const buttons = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll(".place-card");
  const searchInput = document.getElementById("searchInput");

  let currentFilter = "all";

  function filterCards() {
    const searchValue = searchInput.value.toLowerCase();

    cards.forEach(card => {
      const categories = card.dataset.category.split(" ");
      const text = card.innerText.toLowerCase();

      const matchesCategory =
        currentFilter === "all" || categories.includes(currentFilter);

      const matchesSearch =
        text.includes(searchValue);

      if (matchesCategory && matchesSearch) {
        card.style.display = "block";
      } else {
        card.style.display = "none";
      }
    });
  }

  buttons.forEach(button => {
    button.addEventListener("click", function () {
      document.querySelector(".filter-btn.active")?.classList.remove("active");
      this.classList.add("active");
      currentFilter = this.dataset.filter;
      filterCards();
    });
  });

  searchInput.addEventListener("input", filterCards);

});</script>