<section class="hotels section-padding" id="hotels">
  <div class="container">

    <div class="hotels-grid">
  {% for row in rows %}

{% set node = row.content['#row']._entity %}
{% set langcode = row.content['#row'].node_field_data_langcode %}

{% if node.hasTranslation(langcode) %}
  {% set node = node.getTranslation(langcode) %}
{% endif %}

<div class="hotel-card">

  <div class="hotel-img">
    <img src="{{ file_url(node.field_hotel_image.entity.fileuri) }}" alt="{{ node.title.value }}">
  </div>

  <div class="hotel-body">

    <h3>{{ node.title.value }}</h3>

    <div class="hotel-location">
      {{ node.field_hotel_location.value }}
    </div>

    <div class="hotel-amenities">
      {% for item in node.field_amenities %}
        <span>{{ item.value }}</span>
      {% endfor %}
    </div>

            <div class="hotel-footer">
              <div class="price">
                ₹{{ node.field_hotel_price.value }} <small>/night</small>
              </div>

              <a href="#contact" class="btn btn-primary">
                Book
              </a>
            </div>
  </div>
</div>
{% endfor %}
</section>
