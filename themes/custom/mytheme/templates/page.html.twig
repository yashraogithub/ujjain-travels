<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Discover Ujjain - The City of Temples. Explore Mahakaleshwar Temple, Ram Ghat, Kal Bhairav, Sandipani Ashram and more. Book tours, hotels & local services.">
    <meta name="keywords" content="Ujjain, Mahakal Temple, Ram Ghat, Kal Bhairav, Ujjain Tourism, Ujjain Hotels, Ujjain Tours, Madhya Pradesh Tourism">
    <title>Ujjain Tourism | Discover the City of Temples</title>
    <link rel="icon" href="https://public-frontend-cos.metadl.com/mgx/img/favicon_atoms.ico" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

</head>
<body>
<style>
.hero-slider{
  position:relative;
  height:640px;
  overflow:hidden;
}

.hero-bg{
  position:absolute;
  inset:0;
  background-image:url("/sites/default/files/2026-02/h1_0.png");
  background-size:cover;
  background-position:center;
  z-index:1;
}

.hero-overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(
      rgba(0,0,0,0.5),
      rgba(0,0,0,0.6)
  );
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  z-index:2;
}

.hero-content{
  color:#fff;
  position:relative;
  z-index:3;
}

.hero-title{
  font-family:"Playfair Display", serif;
  font-size:48px;
  font-weight:700;
}

.hero-divider{
  width:70px;
  height:3px;
  background:#f4b400;
  margin:20px auto 0;
}
.hero-subtitle{
  font-size:18px;
  margin-bottom:18px;
  opacity:.9;
}

/* breadcrumb */

.hero-breadcrumb{
  font-size:14px;
}
.hero-subtitle,
.hero-breadcrumb{
  white-space: normal;
}
.hero-breadcrumb a{
  color:#ffd369;
  text-decoration:none;
}

.hero-breadcrumb span{
  color:#fff;
}


.top-marq{
background: linear-gradient(90deg,#ff6a00,#ffb347);
color:white;
font-weight:600;
padding:8px 0;
font-size:14px;
}
</style>


<!-- ===== NAVBAR ===== -->
<nav class="navbar" id="navbar">
    <div class="container">
        <a href="#home" class="logo">
            <div class="logo-icon"><i class="fas fa-om"></i></div>
            <span class="logo-text">Mahakal Tourism</span>
        </a>
        <div class="nav-links" id="navLinks">
            {{ page.primary_menu }}
        </div>
       
    <!-- LANGUAGE DROPDOWN -->
    <div class="language-dropdown">

      <button type="button" class="lang-btn">
🌐 {{ language.getName }}
<i class="fas fa-chevron-down"></i>
</button>

      <div class="lang-menu">

  <a href="/en">English</a>
  <a href="/hi">हिन्दी</a>

</div>

    </div>

    <div class="hamburger" id="hamburger">
      <span></span><span></span><span></span>
    </div>

  </div>
</nav>

<!-- ===== HERO SLIDER ===== -->
<section class="hero-slider">

  <div class="hero-bg"></div>

  <div class="hero-overlay">
    <div class="hero-content container">

      <h1 class="hero-title">

        {% if is_front %}
          Discover the City of Temples

        {% elseif node is defined %}
          {{ node.label }}

        {% elseif title %}
          {{ title }}

        {% else %}
          Mahakal Tourism

        {% endif %}

      </h1>
        <p class="hero-subtitle">
          {% if language.getId() == 'hi' %}
          उज्जैन में आध्यात्मिकता, संस्कृति और विरासत का अनुभव करें
          {% else %}
          Experience spirituality, culture and heritage in Ujjain
          {% endif %}
        </p>

    <div class="hero-breadcrumb">

      <a href="/{{ language.getId() }}" style="color:#ffd369">

      {% if language.getId() == 'hi' %}
      मुख्य पृष्ठ
      {% else %}
      Home
      {% endif %}

      </a>

      <span> / </span>

      {% if node is defined %}
      <span>{{ node.label }}</span>
      {% elseif title %}
      <span>{{ title }}</span>
      {% endif %}

    </div>

</section>
{{ page.content }}
<!-- ===== FOOTER ===== -->
{% if node.bundle == 'gallery' %}
  {{ page.gallery }}
{% endif %}

{{ page.footer }}


<a href="https://wa.me/7804025072?text=Hello! I want to plan my Ujjain trip." target="_blank" class="whatsapp-btn" title="Chat on WhatsApp">
    <i class="fab fa-whatsapp"></i>
</a>

<!-- ===== BACK TO TOP ===== -->
<div class="back-to-top" id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <i class="fas fa-arrow-up"></i>
</div>
</body>
</html>


<script>
document.addEventListener("DOMContentLoaded", function () {

    const navbar = document.getElementById("navbar");

    window.addEventListener("scroll", function () {

        if (window.scrollY > 50) {
            navbar.classList.add("scrolled");
        } else {
            navbar.classList.remove("scrolled");
        }
    });
});
</script>