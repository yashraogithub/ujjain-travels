{{ page.sacred_temples }}

<!-- ===== TOUR PACKAGES ===== -->
<section class="packages section-padding" id="packages">
    <div class="container">
        <div class="section-title">
            <h2>Tour Packages</h2>
            <p>Curated spiritual and heritage tour packages to experience the best of Ujjain</p>
        </div>
        <div class="packages-grid">
            <div class="package-card">
                <div class="package-header">
                    <span class="tag">Popular</span>
                    <h3>Ujjain Darshan Package</h3>
                    <div class="duration"><i class="fas fa-calendar-alt"></i> 1 Day / 1 Night</div>
                </div>
                <div class="package-body">
                    <ul class="package-features">
                        <li><i class="fas fa-check-circle"></i> Mahakaleshwar Temple VIP Darshan</li>
                        <li><i class="fas fa-check-circle"></i> Bhasma Aarti Arrangement</li>
                        <li><i class="fas fa-check-circle"></i> Ram Ghat Evening Aarti</li>
                        <li><i class="fas fa-check-circle"></i> Kal Bhairav & Harsiddhi Temple</li>
                        <li><i class="fas fa-check-circle"></i> AC Transport & Guide</li>
                    </ul>
                    <div class="package-footer">
                        <div class="package-price">
                            <span class="amount">₹2,999</span>
                            <span class="per">/person</span>
                        </div>
                        <a href="#contact" class="btn btn-primary" style="padding:10px 20px;font-size:0.85rem;">Book Now</a>
                    </div>
                </div>
            </div>
            <div class="package-card ">
                <div class="package-header">
                    <span class="tag" style="background:var(--gold);">Best Value</span>
                    <h3>Heritage & Spiritual Tour</h3>
                    <div class="duration"><i class="fas fa-calendar-alt"></i> 2 Days / 1 Night</div>
                </div>
                <div class="package-body">
                    <ul class="package-features">
                        <li><i class="fas fa-check-circle"></i> All Major Temples Visit</li>
                        <li><i class="fas fa-check-circle"></i> Sandipani Ashram Tour</li>
                        <li><i class="fas fa-check-circle"></i> Vedha Shala (Observatory)</li>
                        <li><i class="fas fa-check-circle"></i> Hotel Stay with Breakfast</li>
                        <li><i class="fas fa-check-circle"></i> Local Food Experience</li>
                    </ul>
                    <div class="package-footer">
                        <div class="package-price">
                            <span class="amount">₹5,499</span>
                            <span class="per">/person</span>
                        </div>
                        <a href="#contact" class="btn btn-primary" style="padding:10px 20px;font-size:0.85rem;">Book Now</a>
                    </div>
                </div>
            </div>
            <div class="package-card">
                <div class="package-header">
                    <span class="tag" style="background:#4CAF50;">Premium</span>
                    <h3>Complete Ujjain Experience</h3>
                    <div class="duration"><i class="fas fa-calendar-alt"></i> 3 Days / 2 Nights</div>
                </div>
                <div class="package-body">
                    <ul class="package-features">
                        <li><i class="fas fa-check-circle"></i> All Temples + Hidden Gems</li>
                        <li><i class="fas fa-check-circle"></i> Omkareshwar Day Trip</li>
                        <li><i class="fas fa-check-circle"></i> Premium Hotel + All Meals</li>
                        <li><i class="fas fa-check-circle"></i> Private Guide & Vehicle</li>
                        <li><i class="fas fa-check-circle"></i> Photography Session at Ghats</li>
                    </ul>
                    <div class="package-footer">
                        <div class="package-price">
                            <span class="amount">₹9,999</span>
                            <span class="per">/person</span>
                        </div>
                        <a href="#contact" class="btn btn-primary" style="padding:10px 20px;font-size:0.85rem;">Book Now</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ===== GALLERY ===== -->
<section class="gallery section-padding" id="gallery">
    <div class="container">
        <div class="section-title  ">
            <h2>Ujjain Gallery</h2>
            <p>Glimpses of the divine beauty and spiritual aura of Ujjain</p>
        </div>
        <div class="gallery-grid  ">
            <div class="gallery-item" onclick="openLightbox(0)">
                <img src="https://mgx-backend-cdn.metadl.com/generate/images/977678/2026-02-18/ee03b6ef-30d3-43eb-8fdd-226015e4827d.png" alt="Mahakaleshwar Temple" loading="lazy">
                <div class="gallery-overlay"><i class="fas fa-expand"></i></div>
            </div>
            <div class="gallery-item" onclick="openLightbox(1)">
                <img src="https://mgx-backend-cdn.metadl.com/generate/images/977678/2026-02-18/d24806a4-2f5c-4a4e-bfdd-5b85d0fd2d35.png" alt="Ram Ghat Sunset" loading="lazy">
                <div class="gallery-overlay"><i class="fas fa-expand"></i></div>
            </div>
            <div class="gallery-item" onclick="openLightbox(2)">
                <img src="https://mgx-backend-cdn.metadl.com/generate/images/977678/2026-02-18/ea95b97b-af0f-4246-9a50-55998a403e04.png" alt="Kal Bhairav Temple" loading="lazy">
                <div class="gallery-overlay"><i class="fas fa-expand"></i></div>
            </div>
            <div class="gallery-item" onclick="openLightbox(3)">
                <img src="https://mgx-backend-cdn.metadl.com/generate/images/977678/2026-02-18/a40c9f4e-0766-44e2-93ab-647244362c86.png" alt="Sandipani Ashram" loading="lazy">
                <div class="gallery-overlay"><i class="fas fa-expand"></i></div>
            </div>
            <div class="gallery-item" onclick="openLightbox(4)">
                <img src="https://mgx-backend-cdn.metadl.com/generate/images/977678/2026-02-18/3c3b8bd2-cd4a-4766-a01a-4bfb7b15d1a5.png" alt="Ujjain Cityscape" loading="lazy">
                <div class="gallery-overlay"><i class="fas fa-expand"></i></div>
            </div>
            <div class="gallery-item" onclick="openLightbox(5)">
                <img src="https://mgx-backend-cdn.metadl.com/generate/images/977678/2026-02-18/26a902c7-a968-4d81-a4f9-744a429578a0.png" alt="Simhasth Kumbh Mela" loading="lazy">
                <div class="gallery-overlay"><i class="fas fa-expand"></i></div>
            </div>
        </div>
    </div>
</section>

<!-- ===== LIGHTBOX ===== -->
<div class="lightbox" id="lightbox">
    <div class="lightbox-close" onclick="closeLightbox()"><i class="fas fa-times"></i></div>
    <div class="lightbox-nav lightbox-prev" onclick="changeLightbox(-1)"><i class="fas fa-chevron-left"></i></div>
    <img id="lightboxImg" src="" alt="Gallery Image">
    <div class="lightbox-nav lightbox-next" onclick="changeLightbox(1)"><i class="fas fa-chevron-right"></i></div>
</div>



<!-- ===== TESTIMONIALS ===== -->
<section class="testimonials section-padding" id="testimonials">
    <div class="container">
        <div class="section-title  ">
            <h2>What Travelers Say</h2>
            <p>Experiences shared by pilgrims and tourists who visited Ujjain</p>
        </div>
        <div class="testimonials-slider  ">
            <div class="testimonials-track" id="testimonialsTrack">
                <div class="testimonial-card">
                    <div class="testimonial-inner">
                        <div class="quote-icon"><i class="fas fa-quote-left"></i></div>
                        <p>"The Bhasma Aarti at Mahakaleshwar was the most divine experience of my life. The energy inside the temple at 4 AM is indescribable. Ujjain Tourism made our entire trip seamless with their excellent guide and transport services."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">RK</div>
                            <div class="testimonial-info">
                                <h4>Rajesh Kumar</h4>
                                <span>Delhi, India</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="testimonial-inner">
                        <div class="quote-icon"><i class="fas fa-quote-left"></i></div>
                        <p>"We booked the 2-day Heritage & Spiritual Tour and it was worth every rupee. The guide's knowledge about each temple's history and mythology was incredible. Ram Ghat evening aarti was magical!"</p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">PS</div>
                            <div class="testimonial-info">
                                <h4>Priya Sharma</h4>
                                <span>Mumbai, India</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="testimonial-inner">
                        <div class="quote-icon"><i class="fas fa-quote-left"></i></div>
                        <p>"As a history enthusiast, Ujjain exceeded all my expectations. From the ancient Vedha Shala observatory to Sandipani Ashram, every corner of this city tells a story. The local food was absolutely delicious too!"</p>
                        <div class="testimonial-author">
                            <div class="testimonial-avatar">AM</div>
                            <div class="testimonial-info">
                                <h4>Amit Mehta</h4>
                                <span>Ahmedabad, India</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="testimonial-dots" id="testimonialDots">
                <div class="testimonial-dot active" onclick="goToTestimonial(0)"></div>
                <div class="testimonial-dot" onclick="goToTestimonial(1)"></div>
                <div class="testimonial-dot" onclick="goToTestimonial(2)"></div>
            </div>
        </div>
    </div>
</section>



