<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Discover Ujjain - The City of Temples. Explore Mahakaleshwar Temple, Ram Ghat, Kal Bhairav, Sandipani Ashram and more. Book tours, hotels & local services.">
    <meta name="keywords" content="Ujjain, Mahakal Temple, Ram Ghat, Kal Bhairav, Ujjain Tourism, Ujjain Hotels, Ujjain Tours, Madhya Pradesh Tourism">
    <title>Ujjain Tourism | Discover the City of Temples</title>
    <link rel="icon" href="https://public-frontend-cos.metadl.com/mgx/img/favicon_atoms.ico" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
<style>

.navbar .container{
display:flex;
align-items:center;
justify-content:space-between;
}

.nav-center{
display:flex;
gap:25px;
}

.language-dropdown{
position:relative;
}

.lang-btn{
background:transparent;
color:white;
border:none;
padding:6px 12px;
border-radius:4px;
cursor:pointer;
font-weight:600;
}
.lang-btn.scrolled{
  color:black;
}

.lang-menu{
position:absolute;
top:35px;
right:0;
background:white;
box-shadow:0 5px 20px rgba(0,0,0,0.1);
display:none;
flex-direction:column;
min-width:120px;
}

.lang-menu a{
padding:8px 12px;
text-decoration:none;
color:#333;
display:block;
}

.lang-menu a:hover{
background:#f5f5f5;
}

.language-dropdown:hover .lang-menu,
.language-dropdown:focus-within .lang-menu{
display:flex;
}
</style>

<!-- ===== NAVBAR ===== -->
<nav class="navbar" id="navbar">
  <div class="container">

    <!-- LOGO -->
    <a href="/{{ language.getId }}" class="logo">
      <div class="logo-icon"><i class="fas fa-om"></i></div>
      <span class="logo-text">Mahakal Tourism</span>
    </a>

    <!-- MENU -->
    <div class="nav-center">
      {{ page.primary_menu }}
    </div>

    <!-- LANGUAGE DROPDOWN -->
    <div class="language-dropdown">

      <button type="button" class="lang-btn">
🌐 {{ language.getName }}
<i class="fas fa-chevron-down"></i>
</button>

      <div class="lang-menu">

  <a href="/en">English</a>
  <a href="/hi">हिन्दी</a>

</div>

    </div>

    <div class="hamburger" id="hamburger">
      <span></span><span></span><span></span>
    </div>

  </div>
</nav>

<!-- ===== HERO SLIDER ===== -->
{{ page.slider }}


<!-- ===== ABOUT UJJAIN ===== -->
{{ page.about }}

<!-- ===== POPULAR DESTINATIONS ===== -->
{{ page.destination }}

<!-- ===== TEMPLE HIGHLIGHTS ===== -->
{{ page.sacred_temples }}

{{ page.hotels }}

<!-- ===== TOUR PACKAGES ===== -->
{{ page.tour_packages }}
<!-- ===== GALLERY ===== -->
{{ page.gallery }}

{{ page.why_visit }}

{{ page.map }}


<!-- ===== TESTIMONIALS ===== -->
{{ page.reviews }}




<section class="contact section-padding" id="contact">

<div class="container">

{% if language.getId() == 'hi' %}

<div class="section-title">
<h2>संपर्क करें</h2>
<p>अपनी उज्जैन यात्रा की योजना हमारे साथ बनाएं। हम आपकी मदद के लिए यहाँ हैं।</p>
</div>

{% else %}

<div class="section-title">
<h2>Contact Us</h2>
<p>Plan your Ujjain trip with us. We're here to help!</p>
</div>

{% endif %}

<div class="contact-grid">

<div class="contact-info">

<div class="contact-item">
<div class="icon"><i class="fas fa-map-marker-alt"></i></div>
<div>

{% if language.getId() == 'hi' %}
<h4>हमारा कार्यालय</h4>
<p>EWS-75 इंदिरा नगर<br>उज्जैन, मध्य प्रदेश 456001, भारत</p>
{% else %}
<h4>Our Office</h4>
<p>EWS-75 Indira Nagar<br>Ujjain, Madhya Pradesh 456001, India</p>
{% endif %}

</div>
</div>


<div class="contact-item">
<div class="icon"><i class="fas fa-phone"></i></div>
<div>

{% if language.getId() == 'hi' %}
<h4>फ़ोन</h4>
{% else %}
<h4>Phone</h4>
{% endif %}

<p>+91 78040 25072<br>+91 78965 41230</p>

</div>
</div>


<div class="contact-item">
<div class="icon"><i class="fas fa-envelope"></i></div>
<div>

{% if language.getId() == 'hi' %}
<h4>ईमेल</h4>
{% else %}
<h4>Email</h4>
{% endif %}

<p>yashraobhaisare82@gmail.com</p>

</div>
</div>


<div class="contact-item">
<div class="icon"><i class="fas fa-clock"></i></div>
<div>

{% if language.getId() == 'hi' %}
<h4>कार्य समय</h4>
<p>24/7 घंटे</p>
{% else %}
<h4>Working Hours</h4>
<p>24/7 hours</p>
{% endif %}

</div>
</div>

</div>

<div class="contact-form">
{{ drupal_entity('webform', 'contact_us') }}
</div>

</div>
</div>

</section>


<!-- ===== FOOTER ===== -->
{{ page.footer }}

<!-- ===== WHATSAPP BUTTON ===== -->
<a href="https://wa.me/7804025072?text=Hello! I want to plan my Ujjain trip." target="_blank" class="whatsapp-btn" title="Chat on WhatsApp">
    <i class="fab fa-whatsapp"></i>
</a>

<!-- ===== BACK TO TOP ===== -->
<div class="back-to-top" id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <i class="fas fa-arrow-up"></i>
</div>




</body>
</html>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const navbar = document.getElementById("navbar");

    window.addEventListener("scroll", function () {

        if (window.scrollY > 50) {
            navbar.classList.add("scrolled");
        } else {
            navbar.classList.remove("scrolled");
        }

    });

});

</script>
